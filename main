#define GPIOA_MODER		(*(unsigned long *)0x40020000)  //STME32F411
#define GPIOA_OTYPER	(*(unsigned long *)0x40020004)
#define GPIOA_ODR		(*(unsigned long *)0x40020014)

void Main(void)
{
	// LED GPA[7]를 출력(General open drain) 모드로 설정하시오 active low 

	GPIOA_MODER = 0x1 << 14;
	GPIOA_OTYPER = 0x1 << 7;

	// GPA[7] LED를 ON 시키도록 설정하시오

	GPIOA_ODR = 0x0 << 7; 

}
